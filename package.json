{
  "name": "devcollab",
  "version": "1.0.0",
  "description": "Real-time collaborative coding platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build",
    "build:backend": "cd backend && npm install --production",
    "start": "cd backend && npm start",
    "docker:build": "docker build -t devcollab .",
    "docker:run": "docker run -p 5000:5000 devcollab",
    "docker:push": "docker tag devcollab <your-registry>/devcollab:latest && docker push <your-registry>/devcollab:latest"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}